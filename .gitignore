*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------
# Virtual Environment
# ------------------------------------------
venv/
env/
ENV/
.venv/

# ------------------------------------------
# Django
# ------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Django static files
staticfiles/
static/

# ------------------------------------------
# Environment Variables
# ------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------
